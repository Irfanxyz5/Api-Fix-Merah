{
  "version": 2,
  "builds": [{ "src": "api/*.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "/api/send-email", "dest": "/api/send-email.js" },
    { "src": "/api/verify-apikey", "dest": "/api/verify-apikey.js" },
    { "src": "/api/create-transaction", "dest": "/api/create-transaction.js" },
    { "src": "/api/payment-webhook", "dest": "/api/payment-webhook.js" },
    { "src": "/api/telegram-webhook", "dest": "/api/telegram-webhook.js" },
    { "src": "/api/set-telegram-webhook", "dest": "/api/set-telegram-webhook.js" },
    { "src": "/api/cleanup-expired-keys", "dest": "/api/cleanup-expired-keys.js" },
    { "src": "/api/admin", "dest": "/api/admin.js" }
  ]
}